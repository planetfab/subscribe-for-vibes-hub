LINKEDIN_FABRICE_URN=urn:li:person:XXXXXXXXXX
LINKEDIN_MICHELLE_TOKEN=
LINKEDIN_MICHELLE_URN=urn:li:person:XXXXXXXXXX
# PlanetFab company page
