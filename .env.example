# ─── App ────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=replace-with-a-long-random-string

# ─── Users ──────────────────────────────────────────────────────────────────
FABRICE_PASSWORD=choose-a-strong-password
MICHELLE_PASSWORD=choose-a-strong-password

# ─── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email / IMAP ───────────────────────────────────────────────────────────
IMAP_HOST=mail.dreamhost.com
IMAP_PORT=993
IMAP_USER=buzzby@planetfab.com
IMAP_PASSWORD=your-dreamhost-email-password

# ─── Database (Railway PostgreSQL addon) ────────────────────────────────────
